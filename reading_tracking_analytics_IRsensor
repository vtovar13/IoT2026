"""
Reading Tracker (Raspberry Pi + IR sensor) + Gmail email summary

WIRING (recommended safe):
  IR VCC -> Pi 3.3V (Pin 1)
  IR GND -> Pi GND  (Pin 6)
  IR OUT -> GPIO17  (Pin 11)

EMAIL:
  - Uses Gmail SMTP with an App Password stored in env var:
      GMAIL_APP_PASSWORD
  - Put this in ~/.bashrc then run: source ~/.bashrc
"""

import os
import time
import smtplib
from email.message import EmailMessage
from datetime import datetime
import RPi.GPIO as GPIO

# -----------------------
# USER: EDIT THESE
# -----------------------
SENDER_EMAIL = "valmunoz3002@gmail.com"       # <-- put your Gmail here
RECIPIENT_EMAIL = "RECIPIENT_EMAIL_HERE@gmail.com"  # <-- where you want stats sent (can be same as sender)

# -----------------------
# IR SENSOR SETTINGS
# -----------------------
IR_PIN = 17                 # GPIO17 (physical pin 11)
DETECTED_LEVEL = 0          # many IR modules output LOW on detect
DEBOUNCE_SEC = 0.50         # increase if it counts multiple times per flip
SESSION_END_INACTIVITY = 30 # seconds without flips => end session ("book closed")
MIN_SESSION_SEC = 5         # ignore accidental short sessions

# -----------------------
# EMAIL SETTINGS (Gmail)
# -----------------------
SMTP_HOST = "smtp.gmail.com"
SMTP_PORT = 587
EMAIL_SUBJECT = "📚 Reading Session Summary (Physical Book Tracker)"

# Read app password from environment variable set in ~/.bashrc
GMAIL_APP_PASSWORD = os.getenv("GMAIL_APP_PASSWORD")

# -----------------------
# HELPERS
# -----------------------
def format_duration(seconds: float) -> str:
    seconds = int(round(seconds))
    h = seconds // 3600
    m = (seconds % 3600) // 60
    s = seconds % 60
    if h:
        return f"{h}h {m}m {s}s"
    if m:
        return f"{m}m {s}s"
    return f"{s}s"

def build_pretty_email(pages: int, duration_sec: float) -> str:
    minutes = duration_sec / 60.0 if duration_sec > 0 else 0.0
    speed_ppm = (pages / minutes) if minutes > 0 else 0.0
    ended_at = datetime.now().strftime("%Y-%m-%d %H:%M:%S")

    # A clean, presentation-ready plain text email
    body = f"""\
PHYSICAL BOOK READING TRACKER 📖
--------------------------------

Session ended:  {ended_at}
Session length: {format_duration(duration_sec)}
Pages flipped:  {pages}
Speed:          {speed_ppm:.2f} pages/min

How “book closed” is detected:
- The session ends when no page flips are detected for {SESSION_END_INACTIVITY} seconds.

Notes:
- Pages are counted from IR flip events (debounced at {DEBOUNCE_SEC:.2f}s).
- If you see over-counting, increase DEBOUNCE_SEC.
"""
    return body

def send_email(subject: str, body: str) -> None:
    if not GMAIL_APP_PASSWORD:
        raise RuntimeError(
            "GMAIL_APP_PASSWORD is not set. Add it to ~/.bashrc and run: source ~/.bashrc"
        )

    msg = EmailMessage()
    msg["From"] = SENDER_EMAIL
    msg["To"] = RECIPIENT_EMAIL
    msg["Subject"] = subject
    msg.set_content(body)

    with smtplib.SMTP(SMTP_HOST, SMTP_PORT, timeout=20) as server:
        server.ehlo()
        server.starttls()
        server.ehlo()
        server.login(SENDER_EMAIL, GMAIL_APP_PASSWORD)
        server.send_message(msg)

# -----------------------
# MAIN LOGIC
# -----------------------
def main():
    GPIO.setmode(GPIO.BCM)
    GPIO.setup(IR_PIN, GPIO.IN, pull_up_down=GPIO.PUD_UP)

    print("📖 Reading tracker is running.")
    print("Waiting for the first page flip... (Ctrl+C to stop)\n")

    session_active = False
    session_start = None
    last_flip_time = None
    pages = 0

    prev_state = GPIO.input(IR_PIN)
    last_counted_time = 0.0

    try:
        while True:
            state = GPIO.input(IR_PIN)
            now = time.time()

            # Count on transition to DETECTED_LEVEL (edge-based)
            if state != prev_state:
                if state == DETECTED_LEVEL:
                    if (now - last_counted_time) >= DEBOUNCE_SEC:
                        last_counted_time = now

                        if not session_active:
                            session_active = True
                            session_start = now
                            pages = 0
                            print("✅ Session started!")

                        pages += 1
                        last_flip_time = now
                        print(f"Flip detected → pages counted: {pages}")

                prev_state = state

            # End session after inactivity
            if session_active and last_flip_time is not None:
                if (now - last_flip_time) >= SESSION_END_INACTIVITY:
                    duration = now - session_start

                    if duration >= MIN_SESSION_SEC:
                        body = build_pretty_email(pages, duration)
                        print("\n" + body)

                        try:
                            send_email(EMAIL_SUBJECT, body)
                            print("✅ Email sent.\n")
                        except Exception as e:
                            print(f"❌ Email failed: {e}\n")

                    else:
                        print("Session ignored (too short).")

                    # Reset for next session
                    session_active = False
                    session_start = None
                    last_flip_time = None
                    pages = 0
                    print("Waiting for the next session...\n")

            time.sleep(0.01)

    except KeyboardInterrupt:
        print("\nStopping...")

    finally:
        GPIO.cleanup()

if __name__ == "__main__":
    main()
